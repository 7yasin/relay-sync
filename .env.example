# Relay Server Configuration

# Server port
PORT=3080

# Allowed LAN subnet
# Example: 192.168.1. allows devices with IPs like 192.168.1.25
ALLOWED_SUBNET=

# JWT secret used to verify tokens
# Generate your own secret and put it in your local .env file.
JWT_SECRET=replace_this_with_a_long_random_secret

# Optional: JWT max age
# Examples: 7d, 30d, 12h
# Leave empty to allow non-expiring tokens.
JWT_MAX_AGE=

# Optional: rate limit settings
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Optional: helper output buffer size in MB
HELPER_MAX_BUFFER_MB=220

# Optional: maximum copied file size for clipboard base64 transfer in MB
CLIPBOARD_MAX_FILE_MB=100

# Optional: semicolon-separated allowed file roots for GET /file
# Default is the user's home directory.
# Example:
# ALLOWED_FILE_ROOTS=C:\Users\YourName;D:\Shared
ALLOWED_FILE_ROOTS=
